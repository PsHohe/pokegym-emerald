text TestingGrounds_Exterior1_Text_ExpBlockerIntro {
    "Testing EXP curves, are we?\p"
    "Here, take this EXP. BLOCKER.$"
}

text TestingGrounds_Exterior1_Text_ExpBlockerExplain {
    "Use it from the KEY ITEMS pocket to\n"
    "pause or resume EXP for your whole\l"
    "party.\p"
    "Your POKéMON keep earning EVs even\n"
    "while EXP is paused.$"
}

text TestingGrounds_Exterior1_Text_ExpBlockerStatePaused {
    "EXP gain is currently PAUSED.\p"
    "Use the EXP. BLOCKER again to resume\n"
    "it. EVs are still being earned.$"
}

text TestingGrounds_Exterior1_Text_ExpBlockerStateActive {
    "EXP gain is currently ACTIVE.\p"
    "Use the EXP. BLOCKER to pause it\n"
    "whenever you like.$"
}
